{
  "steps": [
    {
      "id": "step_welcome",
      "title": "Welcome & Contact Info",
      "description": "Let's start with your basic information. This takes about 15-25 minutes total.",
      "fields": [
        {
          "id": "field_welcome_heading",
          "type": "heading",
          "label": "Welcome to Your Website Onboarding",
          "content": "We'll walk you through everything we need to build your perfect website. You can save your progress and come back anytime.",
          "required": false
        },
        {
          "id": "field_business_name",
          "type": "text",
          "label": "Business / Organization Name",
          "required": true
        },
        {
          "id": "field_contact_name",
          "type": "text",
          "label": "Your Full Name",
          "required": true
        },
        {
          "id": "field_email",
          "type": "email",
          "label": "Email Address",
          "required": true,
          "placeholder": "you@company.com"
        },
        {
          "id": "field_phone",
          "type": "tel",
          "label": "Phone Number",
          "required": false
        },
        {
          "id": "field_address",
          "type": "address",
          "label": "Business Address (optional)",
          "required": false,
          "placeholder": "Street address, City, State, ZIP"
        },
        {
          "id": "field_existing_url",
          "type": "url",
          "label": "Existing Website URL",
          "required": false,
          "placeholder": "https://"
        },
        {
          "id": "field_business_desc",
          "type": "textarea",
          "label": "In one sentence, what does your business do?",
          "required": true,
          "placeholder": "e.g. We help small bakeries sell cakes online.",
          "rows": 3
        }
      ]
    },
    {
      "id": "step_package",
      "title": "Package Selection",
      "description": "Answer a few quick questions so we can recommend the best package for you.",
      "fields": [
        {
          "id": "field_pkg_heading",
          "type": "heading",
          "label": "Let's find the right package",
          "content": "Answer the questions below and we'll recommend the best fit. You can always change your mind.",
          "required": false
        },
        {
          "id": "field_page_count",
          "type": "radio",
          "label": "Approximately how many pages will your site need?",
          "required": true,
          "options": [
            "1-5 pages (simple brochure site)",
            "6-10 pages (standard business site)",
            "11-25 pages (larger site with sections)",
            "25+ pages (please describe in notes)"
          ]
        },
        {
          "id": "field_ecommerce",
          "type": "radio",
          "label": "Will you be selling products or services online?",
          "required": true,
          "options": [
            "No - just informational",
            "Yes - I need a full online store",
            "Maybe / not sure yet"
          ]
        },
        {
          "id": "field_blog",
          "type": "radio",
          "label": "Will your site have a blog or news section?",
          "required": false,
          "options": [
            "Yes",
            "No",
            "Not sure"
          ]
        },
        {
          "id": "field_integrations_count",
          "type": "radio",
          "label": "How many custom integrations? (CRM, booking, membership, etc.)",
          "required": false,
          "options": [
            "None",
            "1-2",
            "3+"
          ]
        },
        {
          "id": "field_package",
          "type": "package",
          "label": "Select your package",
          "required": true,
          "packageConfig": {
            "packages": [
              {
                "id": "pkg_essentials",
                "name": "Essentials",
                "price": 3000,
                "description": "Up to 5 pages — perfect for simple brochure-style sites"
              },
              {
                "id": "pkg_business",
                "name": "Business",
                "price": 5300,
                "description": "Up to 10 pages — standard business site with all the essentials",
                "badge": "Most Popular"
              },
              {
                "id": "pkg_business_plus",
                "name": "Business+",
                "price": 12000,
                "description": "Up to 25 pages — larger sites with advanced features"
              },
              {
                "id": "pkg_custom",
                "name": "Custom / Enterprise",
                "price": 0,
                "description": "25+ pages or complex needs — let's talk"
              }
            ],
            "features": [
              {
                "label": "Pages included",
                "values": {
                  "pkg_essentials": "Up to 5",
                  "pkg_business": "Up to 10",
                  "pkg_business_plus": "Up to 25",
                  "pkg_custom": "Unlimited"
                }
              },
              {
                "label": "Hosting (1 Year)*",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Standard SSL",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Free CDN",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Premium Theme",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Drag & Drop Page Builder",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Premium Form Plugin",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Premium Media Slider",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Mobile Responsive",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "SEO Friendly",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Google Font Integration",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "User Management",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "WordPress CMS",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Blog Management",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Daily Backups*",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Enhanced Security",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Dynamic Caching*",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Location Map",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Website Staging*",
                "values": {
                  "pkg_essentials": true,
                  "pkg_business": true,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "E-commerce",
                "values": {
                  "pkg_essentials": false,
                  "pkg_business": false,
                  "pkg_business_plus": true,
                  "pkg_custom": true
                }
              },
              {
                "label": "Custom integrations",
                "values": {
                  "pkg_essentials": false,
                  "pkg_business": "Up to 2",
                  "pkg_business_plus": "Up to 5",
                  "pkg_custom": "Unlimited"
                }
              }
            ],
            "rules": [
              {
                "fieldId": "field_page_count",
                "operator": "contains",
                "value": "1-5",
                "recommendedPackageId": "pkg_essentials"
              },
              {
                "fieldId": "field_page_count",
                "operator": "contains",
                "value": "6-10",
                "recommendedPackageId": "pkg_business"
              },
              {
                "fieldId": "field_page_count",
                "operator": "contains",
                "value": "11-25",
                "recommendedPackageId": "pkg_business_plus"
              },
              {
                "fieldId": "field_page_count",
                "operator": "contains",
                "value": "25+",
                "recommendedPackageId": "pkg_custom"
              },
              {
                "fieldId": "field_ecommerce",
                "operator": "contains",
                "value": "Yes",
                "recommendedPackageId": "pkg_business_plus"
              },
              {
                "fieldId": "field_integrations_count",
                "operator": "equals",
                "value": "3+",
                "recommendedPackageId": "pkg_business_plus"
              }
            ],
            "defaultPackageId": "pkg_business"
          },
          "hint": "*Must be hosted with WJD Designs to take part of hosting, SSL, CDN, backup, caching, and staging features."
        }
      ]
    },
    {
      "id": "step_pages",
      "title": "Page Details",
      "description": "Tell us about each page your site needs. We'll ask a few quick questions per page.",
      "fields": [
        {
          "id": "field_pages_heading",
          "type": "heading",
          "label": "Which pages will your site have?",
          "content": "Add each page you want. For every page, we'll ask a few quick questions so we really understand what it needs.",
          "required": false
        },
        {
          "id": "field_pages",
          "type": "repeater",
          "label": "Your Pages",
          "required": true,
          "repeaterConfig": {
            "subFields": [
              {
                "id": "sf_page_type",
                "type": "select",
                "label": "Page Type",
                "required": true,
                "options": [
                  "Home",
                  "About Us",
                  "Services",
                  "Contact",
                  "Blog",
                  "Portfolio/Gallery",
                  "FAQ",
                  "Testimonials",
                  "Team",
                  "Pricing",
                  "Shop/Products",
                  "Custom Page"
                ]
              },
              {
                "id": "sf_custom_name",
                "type": "text",
                "label": "Custom Page Name",
                "required": false,
                "placeholder": "e.g. Our Process",
                "showWhen": {
                  "fieldId": "sf_page_type",
                  "values": ["Custom Page"]
                }
              },
              {
                "id": "sf_purpose",
                "type": "textarea",
                "label": "What is the main purpose of this page?",
                "required": true,
                "placeholder": "What should visitors learn, feel, or do on this page?",
                "rows": 3
              },
              {
                "id": "sf_key_messages",
                "type": "textarea",
                "label": "Key messages or content points",
                "required": false,
                "placeholder": "Bullet points are fine - 3-5 things this page must communicate.",
                "rows": 3
              },
              {
                "id": "sf_cta",
                "type": "text",
                "label": "Primary Call-to-Action",
                "required": false,
                "placeholder": "e.g. \"Schedule a consultation\""
              },
              {
                "id": "sf_services_list",
                "type": "textarea",
                "label": "List the services you offer (one per line)",
                "required": false,
                "hint": "We'll use this list to draft content for each service.",
                "rows": 4,
                "showWhen": {
                  "fieldId": "sf_page_type",
                  "values": ["Services"]
                }
              },
              {
                "id": "sf_about_story",
                "type": "textarea",
                "label": "Tell us about your team / company story",
                "required": false,
                "rows": 4,
                "showWhen": {
                  "fieldId": "sf_page_type",
                  "values": ["About Us", "Team"]
                }
              },
              {
                "id": "sf_faq_examples",
                "type": "textarea",
                "label": "Example FAQs",
                "required": false,
                "rows": 4,
                "showWhen": {
                  "fieldId": "sf_page_type",
                  "values": ["FAQ"]
                }
              },
              {
                "id": "sf_special_features",
                "type": "textarea",
                "label": "Special features or requirements for this page",
                "required": false,
                "placeholder": "e.g. booking calendar, gallery, video hero, map",
                "rows": 3
              }
            ],
            "minEntries": 1,
            "maxEntries": 5,
            "addButtonLabel": "Add Page",
            "entryLabel": "Page"
          }
        }
      ]
    },
    {
      "id": "step_ecommerce",
      "title": "Ecommerce",
      "description": "Tell us about your online store needs.",
      "fields": [
        {
          "id": "field_ecomm_heading",
          "type": "heading",
          "label": "Ecommerce Setup",
          "content": "Let's set up your online store. If you're not selling online, feel free to skip ahead.",
          "required": false
        },
        {
          "id": "field_product_type",
          "type": "radio",
          "label": "Physical goods, digital goods, or both?",
          "required": false,
          "options": [
            "Physical",
            "Digital",
            "Both",
            "Services / bookings"
          ]
        },
        {
          "id": "field_sku_count",
          "type": "number",
          "label": "Approximately how many products/SKUs at launch?",
          "required": false,
          "placeholder": "e.g. 50"
        },
        {
          "id": "field_payment_processors",
          "type": "checkbox",
          "label": "Payment processors you want to accept",
          "required": false,
          "options": [
            "Stripe",
            "PayPal",
            "Square",
            "Apple Pay / Google Pay",
            "Afterpay / Klarna",
            "Crypto",
            "Other"
          ]
        },
        {
          "id": "field_shipping_regions",
          "type": "checkbox",
          "label": "Shipping regions",
          "required": false,
          "options": [
            "United States only",
            "US + Canada",
            "North America",
            "International",
            "Local pickup only",
            "No shipping (digital only)"
          ]
        },
        {
          "id": "field_tax_calc",
          "type": "radio",
          "label": "Need automated tax calculation?",
          "required": false,
          "options": [
            "Yes",
            "No",
            "Not sure"
          ]
        },
        {
          "id": "field_inventory_system",
          "type": "text",
          "label": "Current inventory system (if any)",
          "required": false,
          "placeholder": "e.g. Square POS, QuickBooks"
        },
        {
          "id": "field_ecomm_special",
          "type": "textarea",
          "label": "Special ecommerce requirements?",
          "required": false,
          "placeholder": "Subscriptions, memberships, gift cards, wholesale pricing, etc.",
          "rows": 3
        }
      ]
    },
    {
      "id": "step_branding",
      "title": "Branding & Visual Identity",
      "description": "Help us understand your brand so the site feels like you.",
      "fields": [
        {
          "id": "field_branding_heading",
          "type": "heading",
          "label": "Branding & Visual Identity",
          "content": "Your brand identity shapes every design decision. Share what you have and we'll take it from there.",
          "required": false
        },
        {
          "id": "field_has_logo",
          "type": "radio",
          "label": "Do you have a logo?",
          "required": true,
          "options": [
            "Yes - I'll upload it",
            "Yes - but it needs updating",
            "No - I need one designed"
          ]
        },
        {
          "id": "field_logo_upload",
          "type": "files",
          "label": "Upload your logo (PNG, SVG, AI, PDF preferred)",
          "required": false,
          "accept": "image/*,.ai,.pdf,.eps,.svg",
          "hint": "Upload all versions you have - color, black & white, icon-only, etc."
        },
        {
          "id": "field_color_primary",
          "type": "color",
          "label": "Primary brand color",
          "required": false,
          "placeholder": "#1E88E5"
        },
        {
          "id": "field_color_secondary",
          "type": "color",
          "label": "Secondary brand color",
          "required": false,
          "placeholder": "#0D47A1"
        },
        {
          "id": "field_color_accent",
          "type": "color",
          "label": "Accent color",
          "required": false,
          "placeholder": "#FFC107"
        },
        {
          "id": "field_brand_guidelines",
          "type": "radio",
          "label": "Brand guidelines",
          "required": false,
          "options": [
            "I have a document to upload",
            "I'll describe my brand in text",
            "I don't have guidelines - help me develop them"
          ]
        },
        {
          "id": "field_brand_doc_upload",
          "type": "files",
          "label": "Upload brand guidelines",
          "required": false,
          "accept": ".pdf,.doc,.docx,.ppt,.pptx,.zip",
          "hint": "Style guides, brand books, or any reference documents."
        },
        {
          "id": "field_brand_personality",
          "type": "textarea",
          "label": "Describe your brand personality",
          "required": false,
          "placeholder": "If your brand were a person - professional? playful? bold? sophisticated?",
          "rows": 3
        },
        {
          "id": "field_brand_feelings",
          "type": "textarea",
          "label": "Three words/feelings you want visitors to experience",
          "required": false,
          "placeholder": "e.g. Trustworthy, approachable, expert",
          "rows": 2
        },
        {
          "id": "field_brand_avoid",
          "type": "textarea",
          "label": "Words/feelings to AVOID",
          "required": false,
          "placeholder": "e.g. Stuffy, corporate, cheap",
          "rows": 2
        },
        {
          "id": "field_typography",
          "type": "textarea",
          "label": "Typography preferences",
          "required": false,
          "placeholder": "Modern sans-serif? Classic serif? Specific Google Font?",
          "rows": 2
        }
      ]
    },
    {
      "id": "step_audience",
      "title": "Audience & Inspiration",
      "description": "Who are you trying to reach and what inspires you?",
      "fields": [
        {
          "id": "field_audience_heading",
          "type": "heading",
          "label": "Audience & Inspiration",
          "content": "Understanding your audience and taste helps us design something that connects.",
          "required": false
        },
        {
          "id": "field_target_audience",
          "type": "textarea",
          "label": "Who is your target audience?",
          "required": true,
          "placeholder": "Be specific - demographics, pain points, what they care about.",
          "rows": 4
        },
        {
          "id": "field_value_prop",
          "type": "textarea",
          "label": "Your one-sentence value proposition",
          "required": true,
          "placeholder": "\"We help [audience] achieve [outcome] by [method].\"",
          "rows": 2
        },
        {
          "id": "field_competitors",
          "type": "textarea",
          "label": "Your top 3 competitors (with URLs if possible)",
          "required": false,
          "placeholder": "competitor1.com - they do X well\ncompetitor2.com - we want to differentiate from Y",
          "rows": 4
        },
        {
          "id": "field_inspiration_sites",
          "type": "textarea",
          "label": "Websites you love (and why)",
          "required": false,
          "placeholder": "Paste URLs and note what you like - layout, colors, feel, specific features",
          "hint": "Add up to 5 inspiration sites. Paste the URL and say what you like.",
          "rows": 5
        },
        {
          "id": "field_dislike_sites",
          "type": "textarea",
          "label": "Sites or styles you DON'T want to look like",
          "required": false,
          "placeholder": "What turns you off? Overly corporate? Too minimal? Cluttered?",
          "rows": 3
        }
      ]
    },
    {
      "id": "step_content_integrations",
      "title": "Content, Integrations & Launch",
      "description": "Final details - content, technical setup, and launch timeline.",
      "fields": [
        {
          "id": "field_content_heading",
          "type": "heading",
          "label": "Content, Integrations & Launch",
          "content": "Almost there - let's nail down the technical details and timeline.",
          "required": false
        },
        {
          "id": "field_copywriting",
          "type": "radio",
          "label": "Who writes the website copy?",
          "required": true,
          "options": [
            "I have copy ready / I'll write it",
            "Collaborative - I draft, you polish",
            "Please write it for me (copywriting add-on)",
            "Not sure yet"
          ]
        },
        {
          "id": "field_existing_assets",
          "type": "checkbox",
          "label": "Which assets do you already have?",
          "required": false,
          "options": [
            "Professional photos",
            "Videos",
            "Written copy",
            "Customer testimonials",
            "Case studies",
            "Existing brand assets",
            "None of the above"
          ]
        },
        {
          "id": "field_stock_photos",
          "type": "radio",
          "label": "Need stock photography?",
          "required": false,
          "options": [
            "Yes please",
            "No - I have photos",
            "Mix of both"
          ]
        },
        {
          "id": "field_domain",
          "type": "text",
          "label": "Current domain name",
          "required": false,
          "placeholder": "yourbusiness.com"
        },
        {
          "id": "field_domain_status",
          "type": "radio",
          "label": "Domain status",
          "required": false,
          "options": [
            "I own it and have access",
            "I own it but need help accessing",
            "I need to purchase a domain",
            "Not sure"
          ]
        },
        {
          "id": "field_hosting",
          "type": "radio",
          "label": "Current hosting",
          "required": false,
          "options": [
            "I have hosting I want to keep",
            "Move to WJD Designs hosting",
            "No existing hosting - use WJD Designs",
            "Not sure"
          ]
        },
        {
          "id": "field_integrations",
          "type": "checkbox",
          "label": "Integrations you need",
          "required": false,
          "options": [
            "Mailchimp / email marketing",
            "HubSpot / CRM",
            "Google Analytics 4",
            "Google Tag Manager",
            "Meta / Facebook Pixel",
            "Calendly / booking system",
            "Zapier / Make automations",
            "Live chat",
            "Membership / gated content",
            "Multi-language translation",
            "Google Maps / location features"
          ]
        },
        {
          "id": "field_integrations_other",
          "type": "textarea",
          "label": "Other tools or integrations not listed above",
          "required": false,
          "placeholder": "Any other software, tools, or APIs you need connected",
          "rows": 3
        },
        {
          "id": "field_accessibility",
          "type": "radio",
          "label": "Accessibility requirements",
          "required": false,
          "options": [
            "WCAG 2.1 AA (recommended)",
            "Section 508",
            "ADA compliance",
            "No specific requirements"
          ]
        },
        {
          "id": "field_launch_date",
          "type": "date",
          "label": "Desired launch date",
          "required": false
        },
        {
          "id": "field_approver",
          "type": "text",
          "label": "Who has final approval on the site?",
          "required": false,
          "placeholder": "Name + role"
        },
        {
          "id": "field_success",
          "type": "textarea",
          "label": "What does success look like 6 months after launch?",
          "required": false,
          "placeholder": "More leads? Specific traffic numbers? Less phone calls? Be concrete.",
          "rows": 3
        },
        {
          "id": "field_budget_notes",
          "type": "textarea",
          "label": "Budget notes / anything else we should know?",
          "required": false,
          "rows": 3
        }
      ]
    },
